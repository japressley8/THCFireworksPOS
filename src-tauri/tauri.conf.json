{
  "productName": "THC_Fireworks",
  "version": "27.1.6",
  "identifier": "com.church.thcfireworks",
  "build": {
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "THC Fireworks - POS Terminal",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/japressley8/THCFireworksPOS/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNEVBRDhGMDU5QTVCRDkKUldUWlc1b0ZqNjFPSTZMNVc5WTlMcFR3bzNsSzBQTC9hUzM0UmRBY211RFpsaVd2K2dhZVI5Tm8K"
    }
  }
}
